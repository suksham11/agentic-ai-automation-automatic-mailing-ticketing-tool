APP_NAME=customer-support-agent
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
API_AUTH_ENABLED=false
API_KEY=
API_KEY_HEADER=X-API-Key
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Model provider settings
MODEL_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Integrations
ZENDESK_BASE_URL=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
GMAIL_SENDER_EMAIL=
GMAIL_ACCESS_TOKEN=
GMAIL_REFRESH_TOKEN=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_TOKEN_URL=https://oauth2.googleapis.com/token
EMAIL_DELIVERY_MODE=safe
EMAIL_ALLOWED_RECIPIENTS=

# Data stores
POSTGRES_DSN=postgresql+psycopg://postgres:postgres@localhost:5433/support_agent
REDIS_URL=redis://redis:6379/0

# Retrieval data
KB_DIR=./data/kb
